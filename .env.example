PORT=3002
MONGO_URI=mongodb://mongo-users:27017/users
JWT_SECRET=cambiar-por-secret-fuerte
ADMIN_PROMOTE_SECRET=cambiar-por-secret-fuerte

# IMPORTANTE: JWT_SECRET debe ser IDÉNTICO al usado en auth-service.
# Los tokens emitidos por auth-service se verifican aquí.
